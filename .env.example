# DeepSeek API — get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Telegram — create a bot with @BotFather, then send /start to it and
# grab your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Default timezone for cron jobs (e.g. Asia/Kuala_Lumpur, America/New_York)
LEON_TIMEZONE=Asia/Kuala_Lumpur

# Default location for the seeded "weather" data source (Open-Meteo, no key needed).
# Shah Alam, Selangor by default. Change if you want weather for a different city.
LEON_LATITUDE=3.07
LEON_LONGITUDE=101.52

# Optional: add tokens here for any data sources you register in data/sources.json
# Example reference inside sources.json: "url": "...&appid={env:OPENWEATHER_KEY}"
# OPENWEATHER_KEY=
# WEATHERAPI_KEY=
